{
  "id": null,
  "uid": "social-media-mvp",
  "title": "Social Media Trends Pipeline",
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 40,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
      {
        "id": 1,
        "title": "Top Hashtags en Tiempo Real",
        "type": "barchart",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "datasource": "PostgreSQL",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        },
        "options": {
          "orientation": "horizontal",
          "legend": { "displayMode": "table", "placement": "bottom" }
        },
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT hashtag AS metric, total_posts AS value FROM trending_hashtags WHERE window_start >= NOW() - INTERVAL '1 hour' ORDER BY total_posts DESC LIMIT 10",
            "format": "table"
          }
        ]
      },
      {
        "id": 2,
        "title": "Distribución de Sentimientos",
        "type": "piechart",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "datasource": "PostgreSQL",
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right" }
        },
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT sentiment AS metric, COUNT(*) AS value FROM sentiment_analysis WHERE timestamp >= NOW() - INTERVAL '1 hour' GROUP BY sentiment",
            "format": "table"
          }
        ]
      },
      {
        "id": 3,
        "title": "Volumen de Posts por Ventana",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
        "datasource": "PostgreSQL",
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 10 }
          }
        },
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT window_start as time, total_posts FROM trending_hashtags WHERE window_start >= NOW() - INTERVAL '1 hour' ORDER BY window_start",
            "format": "timeseries"
          }
        ]
      },
      {
        "id": 4,
        "title": "Últimas Alertas (Contenido Sensible)",
        "type": "table",
        "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
        "datasource": "PostgreSQL",
        "options": {
          "footer": { "show": true, "reducer": ["count"] }
        },
        "targets": [
          {
            "refId": "A",
            "rawSql": "SELECT username, text, alert_reason, timestamp FROM alert_events WHERE timestamp >= NOW() - INTERVAL '1 hour' ORDER BY timestamp DESC LIMIT 20",
            "format": "table"
          }
        ]
      }
],
  "overwrite": true
}
