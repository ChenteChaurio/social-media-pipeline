{
  "dashboard": {
    "title": "Social Media Trends Pipeline",
    "uid": "social-media-mvp",
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Top Hashtags en Tiempo Real",
        "type": "bargauge",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "options": {
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "targets": [
          {
            "rawQuery": true,
            "rawSql": "SELECT hashtag, total_posts FROM top_hashtags ORDER BY total_posts DESC LIMIT 10"
          }
        ]
      },
      {
        "id": 2,
        "title": "Sentimiento General",
        "type": "piechart",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right" }
        },
        "targets": [
          {
            "rawQuery": true,
            "rawSql": "SELECT sentiment, COUNT(*) as total FROM sentiment_events GROUP BY sentiment"
          }
        ]
      },
      {
        "id": 3,
        "title": "Volumen de Posts por Minuto",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 10 }
          }
        },
        "targets": [
          {
            "rawQuery": true,
            "rawSql": "SELECT window_start as time, post_count FROM trending_hashtags ORDER BY time"
          }
        ]
      },
      {
        "id": 4,
        "title": "Alertas de Contenido Sensible",
        "type": "table",
        "gridPos": { "x": 0, "y": 16, "w": 24, "h": 6 },
        "options": {
          "footer": { "show": true, "reducer": ["count"] }
        },
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "sentiment" },
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "positivo": { "color": "green" } } },
                    { "type": "value", "options": { "negativo": { "color": "red" } } },
                    { "type": "value", "options": { "neutro":   { "color": "yellow" } } }
                  ]
                }
              ]
            }
          ]
        },
        "targets": [
          {
            "rawQuery": true,
            "rawSql": "SELECT user, text, timestamp FROM alert_events ORDER BY timestamp DESC LIMIT 20"
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" }
  },
  "overwrite": true
}
